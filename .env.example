# Example .env for the EMA crossover bot

# Exchange id (ccxt exchange id). Default: coinbasepro
EXCHANGE=coinbasepro

# Live toggle: false = paper mode
LIVE=false

# API credentials for live trading (do NOT commit real keys)
COINBASE_API_KEY=
COINBASE_SECRET=
COINBASE_PASSWORD=

# Comma-separated symbol list. Normalize to exchange format if needed.
# For Coinbase, prefer e.g. BTC-USD, ETH-USD
SYMBOLS=BTC-USD,ETH-USD,SOL-USD,XRP-USD,XLM-USD,BTC-EUR,ETH-EUR,BTC-GBP,NEAR-USD,DOGE-USD,USDC-EUR,ZEC-USD

# Strategy parameters
EMA_SHORT=12
EMA_LONG=26
CONFIRMATION_REQUIRED=2

# Risk controls
MAX_POSITION_PCT=0.05
MAX_DRAWDOWN=0.10
MAX_POSITIONS=1
